<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ========== COLOR PALETTE ========== -->
    <!-- Dark Theme - Professional Trading Workstation Style -->

    <Color x:Key="DS_Background">#0F1115</Color>
    <Color x:Key="DS_SecondaryBg">#171B22</Color>
    <Color x:Key="DS_PanelSurface">#1A1F29</Color>
    <Color x:Key="DS_Border">#2D3748</Color>
    <Color x:Key="DS_PrimaryText">#E5E7EB</Color>
    <Color x:Key="DS_SecondaryText">#9CA3AF</Color>
    <Color x:Key="DS_Accent">#F5C400</Color>
    <Color x:Key="DS_Success">#22C55E</Color>
    <Color x:Key="DS_Danger">#EF4444</Color>
    <Color x:Key="DS_Warning">#F59E0B</Color>

    <!-- ========== SOLID COLOR BRUSHES ========== -->

    <SolidColorBrush x:Key="DS_BackgroundBrush" Color="{StaticResource DS_Background}" />
    <SolidColorBrush x:Key="DS_SecondaryBgBrush" Color="{StaticResource DS_SecondaryBg}" />
    <SolidColorBrush x:Key="DS_PanelSurfaceBrush" Color="{StaticResource DS_PanelSurface}" />
    <SolidColorBrush x:Key="DS_BorderBrush" Color="{StaticResource DS_Border}" />
    <SolidColorBrush x:Key="DS_PrimaryTextBrush" Color="{StaticResource DS_PrimaryText}" />
    <SolidColorBrush x:Key="DS_SecondaryTextBrush" Color="{StaticResource DS_SecondaryText}" />
    <SolidColorBrush x:Key="DS_AccentBrush" Color="{StaticResource DS_Accent}" />
    <SolidColorBrush x:Key="DS_SuccessBrush" Color="{StaticResource DS_Success}" />
    <SolidColorBrush x:Key="DS_DangerBrush" Color="{StaticResource DS_Danger}" />
    <SolidColorBrush x:Key="DS_WarningBrush" Color="{StaticResource DS_Warning}" />

    <!-- ========== SPACING CONSTANTS (8px base unit) ========== -->

    <sys:Double x:Key="DS_Spacing_XS">4</sys:Double>
    <sys:Double x:Key="DS_Spacing_S">8</sys:Double>
    <sys:Double x:Key="DS_Spacing_M">16</sys:Double>
    <sys:Double x:Key="DS_Spacing_L">24</sys:Double>
    <sys:Double x:Key="DS_Spacing_XL">32</sys:Double>
    <sys:Double x:Key="DS_Spacing_2XL">48</sys:Double>

    <!-- ========== SIZING CONSTANTS ========== -->

    <sys:Double x:Key="DS_BorderRadius">6</sys:Double>
    <sys:Double x:Key="DS_BorderThickness">1</sys:Double>
    <Thickness x:Key="DS_Padding_Small">8,6</Thickness>
    <Thickness x:Key="DS_Padding_Medium">12,8</Thickness>
    <Thickness x:Key="DS_Padding_Large">16,12</Thickness>

    <!-- ========== TYPOGRAPHY STYLES ========== -->

    <!-- Title 22px, SemiBold -->
    <Style x:Key="DS_Title22" TargetType="TextBlock">
        <Setter Property="FontSize" Value="22" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource DS_PrimaryTextBrush}" />
        <Setter Property="FontFamily" Value="Segoe UI" />
    </Style>

    <!-- Section Title 16px, SemiBold -->
    <Style x:Key="DS_SectionTitle16" TargetType="TextBlock">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource DS_PrimaryTextBrush}" />
        <Setter Property="FontFamily" Value="Segoe UI" />
    </Style>

    <!-- Body 13px, Regular -->
    <Style x:Key="DS_Body13" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="{StaticResource DS_PrimaryTextBrush}" />
        <Setter Property="FontFamily" Value="Segoe UI" />
    </Style>

    <!-- Caption 11px, Regular, Secondary Text Color -->
    <Style x:Key="DS_Caption11" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="{StaticResource DS_SecondaryTextBrush}" />
        <Setter Property="FontFamily" Value="Segoe UI" />
    </Style>

    <!-- ========== MODULE TEMPLATE CONSTANTS ========== -->

    <sys:Double x:Key="DS_HeaderBottomMargin">12</sys:Double>
    <sys:Double x:Key="DS_SectionMargin">12</sys:Double>
    <sys:Double x:Key="DS_MetricRowHeight">60</sys:Double>
    <sys:Double x:Key="DS_LargeMetricHeight">120</sys:Double>
    <Thickness x:Key="DS_CardPadding">8</Thickness>
    <Thickness x:Key="DS_MetricCardPadding">12,8</Thickness>

    <!-- ========== CARD STYLE VARIANTS ========== -->

    <!-- Primary Card: Large metrics display (120px height, emphasis) -->
    <Style x:Key="PrimaryCard" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource DS_PanelSurfaceBrush}" />
        <Setter Property="CornerRadius" Value="{StaticResource DS_BorderRadius}" />
        <Setter Property="Padding" Value="{StaticResource DS_MetricCardPadding}" />
        <Setter Property="Margin" Value="8" />
        <Setter Property="MinHeight" Value="{StaticResource DS_LargeMetricHeight}" />
        <Setter Property="BorderBrush" Value="{StaticResource DS_SecondaryBgBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,2" />
    </Style>

    <!-- Secondary Card: Standard data display -->
    <Style x:Key="SecondaryCard" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource DS_PanelSurfaceBrush}" />
        <Setter Property="CornerRadius" Value="{StaticResource DS_BorderRadius}" />
        <Setter Property="Padding" Value="{StaticResource DS_CardPadding}" />
        <Setter Property="Margin" Value="8" />
        <Setter Property="MinHeight" Value="{StaticResource DS_MetricRowHeight}" />
        <Setter Property="BorderBrush" Value="{StaticResource DS_SecondaryBgBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <!-- Tertiary Card: Text-only metrics (no border, minimal styling) -->
    <Style x:Key="TertiaryCard" TargetType="Border">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="CornerRadius" Value="{StaticResource DS_BorderRadius}" />
        <Setter Property="Padding" Value="{StaticResource DS_CardPadding}" />
        <Setter Property="Margin" Value="8" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <!-- Metric Value Style: Large, bold numbers for primary cards -->
    <Style x:Key="DS_MetricValue" TargetType="TextBlock">
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource DS_PrimaryTextBrush}" />
        <Setter Property="FontFamily" Value="Segoe UI" />
    </Style>

    <!-- Metric Label Style: Secondary text for metric descriptions -->
    <Style x:Key="DS_MetricLabel" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="{StaticResource DS_SecondaryTextBrush}" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="Margin" Value="0,0,0,4" />
    </Style>

</ResourceDictionary>
