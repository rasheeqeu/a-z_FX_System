<Window x:Class="ForexTradingWorkspace.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:ForexTradingWorkspace.Converters"
        xmlns:shell="clr-namespace:ForexTradingWorkspace.Models.Shell"
        xmlns:learning="clr-namespace:ForexTradingWorkspace.Models.Learning"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:sys="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Forex Demo Learning Workspace"
        Width="1120"
        Height="740"
        MinWidth="860"
        MinHeight="620"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        WindowStyle="None"
        AllowsTransparency="True">
    <sys:WindowChrome.WindowChrome>
        <sys:WindowChrome GlassFrameThickness="0,0,0,0" CaptionHeight="52" />
    </sys:WindowChrome.WindowChrome>
    <Window.Resources>
        <converters:UrlToUriConverter x:Key="UrlToUriConverter" />
        <converters:StringEqualsConverter x:Key="StringEqualsConverter" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <Style x:Key="Panel" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource DS_SecondaryBgBrush}" />
            <Setter Property="CornerRadius" Value="6,6,6,6" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="8" />
        </Style>

        <Style x:Key="StepButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Margin" Value="0,4" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource DS_SecondaryTextBrush}" />
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource DS_SecondaryTextBrush}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Margin" Value="0,10,0,3" />
        </Style>

        <Style x:Key="Metric" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource DS_PanelSurfaceBrush}" />
            <Setter Property="CornerRadius" Value="6,6,6,6" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Margin" Value="4" />
            <Setter Property="MinWidth" Value="130" />
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource DS_BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="52" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource DS_SecondaryBgBrush}" Padding="16,8" sys:WindowChrome.IsHitTestVisibleInChrome="True" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,0">
                    <!-- Window Control Buttons -->
                    <Button x:Name="MinimizeButton" Content="−" Padding="12,4" Margin="4,0,2,0" Width="36" Height="32" ToolTip="Minimize" Click="MinimizeButton_Click" />
                    <Button x:Name="MaximizeButton" Content="□" Padding="12,4" Margin="2,0,2,0" Width="36" Height="32" ToolTip="Maximize" Click="MaximizeButton_Click" />
                    <Button x:Name="CloseButton" Content="✕" Padding="12,4" Margin="2,0,0,0" Width="36" Height="32" ToolTip="Close" Click="CloseButton_Click" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                    <TextBlock Text="{Binding LocalClock}" Foreground="{StaticResource DS_SecondaryTextBrush}" Margin="12,0" />
                    <Button x:Name="SessionButton" Content="📈" Command="{Binding ToggleSessionPanelCommand}" Padding="8,5" Margin="4,0,8,0" Background="{StaticResource DS_PanelSurfaceBrush}" ToolTip="View Forex trading sessions" FontSize="16" />
                    <Button Content="✎ Edit Lessons" Command="{Binding OpenLessonEditorCommand}" Padding="12,5" Margin="0,0,8,0" Background="{StaticResource DS_PanelSurfaceBrush}"/>
                    <Button Content="Ask AI" Command="{Binding ExportAiReviewCommand}" Padding="12,5" />
                    <Button Content="Back" Command="{Binding PreviousStepCommand}" Padding="10,5" />
                    <Button Content="{Binding NextButtonText}" Command="{Binding NextStepCommand}" Padding="16,5" Background="{StaticResource DS_AccentBrush}" Foreground="#111111" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Forex Demo Learning Workspace" FontSize="16" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding ProgressText}" Foreground="{StaticResource DS_SecondaryTextBrush}" Margin="18,1,0,0" />
                    <TextBlock Text="{Binding CurrentStepTitle}" Foreground="{StaticResource DS_AccentBrush}" Margin="10,1,0,0" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Session Panel Dropdown -->
        <Border Grid.Row="0"
                Background="{StaticResource DS_SecondaryBgBrush}"
                BorderBrush="{StaticResource DS_PanelSurfaceBrush}"
                BorderThickness="1"
                CornerRadius="6,6,6,6"
                Padding="12"
                Margin="0,52,8,0"
                Visibility="{Binding IsSessionPanelOpen, Converter={StaticResource BoolToVisibilityConverter}}"
                Width="400"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Panel.ZIndex="100">
                <StackPanel>
                    <!-- Session List -->
                    <TextBlock Text="Forex Trading Sessions" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <ItemsControl ItemsSource="{Binding SessionsData}" Margin="0,0,0,12">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource DS_PanelSurfaceBrush}"
                                        CornerRadius="4,4,4,4"
                                        Padding="10,8"
                                        Margin="0,0,0,6">
                                    <StackPanel>
                                        <DockPanel Margin="0,0,0,4">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding TimeUntilChangeDisplay}"
                                                       Foreground="{StaticResource DS_SecondaryTextBrush}"
                                                       FontSize="11"
                                                       DockPanel.Dock="Right"
                                                       TextAlignment="Right" />
                                        </DockPanel>
                                        <TextBlock Text="{Binding LocalOpen, StringFormat='Local: {0:HH:mm}'}" Foreground="{StaticResource DS_SecondaryTextBrush}" FontSize="11" />
                                        <TextBlock Text="{Binding LocalClose, StringFormat='to {0:HH:mm}'}" Foreground="{StaticResource DS_SecondaryTextBrush}" FontSize="11" Margin="0,2,0,0" />
                                        <TextBlock Text="{Binding UtcOpen, StringFormat='UTC: {0:HH:mm}'}" Foreground="{StaticResource DS_SecondaryTextBrush}" FontSize="10" Margin="0,2,0,0" />
                                        <TextBlock FontSize="10"
                                                   Margin="0,4,0,0"
                                                   Foreground="{StaticResource DS_AccentBrush}"
                                                   Visibility="{Binding IsCurrentlyOpen, Converter={StaticResource BoolToVisibilityConverter}}">
                                            ✓ Currently Open
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Visual Timeline -->
                    <TextBlock Text="24-Hour Timeline" FontWeight="SemiBold" Margin="0,0,0,8" FontSize="12" />
                    <Border Background="{StaticResource DS_PanelSurfaceBrush}" CornerRadius="4,4,4,4" Padding="8" Margin="0,0,0,12">
                        <StackPanel>
                            <!-- Hour Markers -->
                            <Grid Height="16" Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition />
                                    <ColumnDefinition />
                                    <ColumnDefinition />
                                    <ColumnDefinition />
                                    <ColumnDefinition />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="00:00" FontSize="8" Foreground="{StaticResource DS_SecondaryTextBrush}" />
                                <TextBlock Text="06:00" Grid.Column="1" FontSize="8" Foreground="{StaticResource DS_SecondaryTextBrush}" HorizontalAlignment="Center" />
                                <TextBlock Text="12:00" Grid.Column="2" FontSize="8" Foreground="{StaticResource DS_SecondaryTextBrush}" HorizontalAlignment="Center" />
                                <TextBlock Text="18:00" Grid.Column="3" FontSize="8" Foreground="{StaticResource DS_SecondaryTextBrush}" HorizontalAlignment="Center" />
                                <TextBlock Text="24:00" Grid.Column="4" FontSize="8" Foreground="{StaticResource DS_SecondaryTextBrush}" HorizontalAlignment="Right" />
                            </Grid>
                            <!-- Session Bars -->
                            <Canvas Height="60">
                                <!-- Sydney Bar (22:00-07:00 UTC) -->
                                <Rectangle Canvas.Left="183" Canvas.Top="4" Width="58" Height="10" Fill="#4CAF50" Opacity="0.7" ToolTip="Sydney: 22:00-07:00 UTC" />
                                <!-- Tokyo Bar (00:00-09:00 UTC) -->
                                <Rectangle Canvas.Left="0" Canvas.Top="16" Width="38" Height="10" Fill="#2196F3" Opacity="0.7" ToolTip="Tokyo: 00:00-09:00 UTC" />
                                <!-- London Bar (08:00-17:00 UTC) -->
                                <Rectangle Canvas.Left="53" Canvas.Top="28" Width="75" Height="10" Fill="#FF9800" Opacity="0.7" ToolTip="London: 08:00-17:00 UTC" />
                                <!-- New York Bar (13:00-22:00 UTC) -->
                                <Rectangle Canvas.Left="87" Canvas.Top="40" Width="75" Height="10" Fill="#E91E63" Opacity="0.7" ToolTip="New York: 13:00-22:00 UTC" />
                                <!-- Current Time Marker -->
                                <Line X1="150" Y1="0" X2="150" Y2="60" Stroke="{StaticResource DS_AccentBrush}" StrokeThickness="2" />
                            </Canvas>
                        </StackPanel>
                    </Border>

                    <!-- Overlap Info -->
                    <TextBlock Text="London-New York Overlap: 13:00-17:00 UTC"
                               FontSize="11"
                               Foreground="{StaticResource DS_AccentBrush}"
                               TextWrapping="Wrap" />
                </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="260" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource DS_BackgroundBrush}" Padding="10" Visibility="Collapsed">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top">
                        <TextBlock Text="Practice Flow" Foreground="{StaticResource DS_SecondaryTextBrush}" Margin="8,4,0,10" />
                        <Button Style="{StaticResource StepButton}" Content="1. Choose Lesson" Command="{Binding GoToStepCommand}" CommandParameter="{x:Static shell:GuidedStep.ChooseLesson}" />
                        <Button Style="{StaticResource StepButton}" Content="2. Evaluate" Command="{Binding GoToStepCommand}" CommandParameter="{x:Static shell:GuidedStep.EvaluateUnderstanding}" />
                        <Button Style="{StaticResource StepButton}" Content="3. Trade Idea" Command="{Binding GoToStepCommand}" CommandParameter="{x:Static shell:GuidedStep.PlanSetup}" />
                        <Button Style="{StaticResource StepButton}" Content="4. Prices" Command="{Binding GoToStepCommand}" CommandParameter="{x:Static shell:GuidedStep.EnterPrices}" />
                        <Button Style="{StaticResource StepButton}" Content="5. Risk Check" Command="{Binding GoToStepCommand}" CommandParameter="{x:Static shell:GuidedStep.CheckRisk}" />
                        <Button Style="{StaticResource StepButton}" Content="6. Screenshot" Command="{Binding GoToStepCommand}" CommandParameter="{x:Static shell:GuidedStep.CaptureScreenshot}" />
                        <Button Style="{StaticResource StepButton}" Content="7. XM Demo" Command="{Binding GoToStepCommand}" CommandParameter="{x:Static shell:GuidedStep.ManualExecution}" />
                        <Button Style="{StaticResource StepButton}" Content="8. Journal" Command="{Binding GoToStepCommand}" CommandParameter="{x:Static shell:GuidedStep.JournalReview}" />
                    </StackPanel>
                    <StackPanel DockPanel.Dock="Bottom">
                        <TextBlock Text="Rule" Foreground="{StaticResource DS_SecondaryTextBrush}" Margin="8,0,0,4" />
                        <TextBlock Text="Do not place a demo trade until risk, checklist, and screenshot are complete." TextWrapping="Wrap" Margin="8,0" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <Grid Grid.Column="1">
                <Border Style="{StaticResource Panel}" Visibility="{Binding CurrentStep, Converter={StaticResource StringEqualsConverter}, ConverterParameter=ChooseLesson}">
                    <StackPanel MaxWidth="720" HorizontalAlignment="Left">
                        <TextBlock Text="{Binding Learning.LessonPosition}" Foreground="{StaticResource DS_SecondaryTextBrush}" />
                        <TextBlock Text="{Binding Learning.SelectedLesson.DisplayTitle, TargetNullValue='Select a lesson'}" Style="{StaticResource DS_Title22}" Margin="0,8,0,0" />
                        <TextBlock Text="{Binding Learning.SelectedLesson.Lesson.Summary}" TextWrapping="Wrap" Margin="0,12,0,0" />
                        <Border Background="{StaticResource DS_PanelSurfaceBrush}" CornerRadius="6,6,6,6" Padding="12" Margin="0,18,0,0">
                            <StackPanel>
                                <TextBlock Text="Eligibility for demo practice" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding Learning.LearningGateMessage}" TextWrapping="Wrap" Foreground="{StaticResource DS_SecondaryTextBrush}" Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>
                        <TextBlock Text="Write one thing you understand from this lesson" Style="{StaticResource DS_SectionTitle16}" Margin="0,28,0,8" />
                        <TextBox Text="{Binding Learning.PracticeAnswer, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" MinHeight="150" TextWrapping="Wrap" />
                        <WrapPanel Margin="0,14,0,0">
                            <Button Content="Previous Lesson" Command="{Binding Learning.PreviousLessonCommand}" />
                            <Button Content="Next Lesson" Command="{Binding Learning.NextLessonCommand}" />
                            <Button Content="Save Understanding" Command="{Binding Learning.SavePracticeCommand}" />
                            <Button Content="Evaluate Understanding" Command="{Binding NextStepCommand}" IsEnabled="{Binding Learning.CanEvaluateSelectedLesson}" Background="{StaticResource DS_AccentBrush}" Foreground="#111111" />
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Panel}" Visibility="{Binding CurrentStep, Converter={StaticResource StringEqualsConverter}, ConverterParameter=EvaluateUnderstanding}">
                    <ScrollViewer>
                        <StackPanel MaxWidth="760" HorizontalAlignment="Left">
                            <TextBlock Text="{Binding Learning.SelectedLesson.DisplayTitle, TargetNullValue='Select a lesson'}" Style="{StaticResource DS_Title22}" />
                            <TextBlock Text="Evaluation: use any AI manually" Style="{StaticResource DS_SectionTitle16}" Margin="0,18,0,8" />
                            <TextBlock Text="Write your explanation, copy the evaluation prompt, paste it into any AI, then paste the returned JSON here. The app parses that JSON to unlock Trade Idea." TextWrapping="Wrap" Foreground="{StaticResource DS_SecondaryTextBrush}" />
                            <TextBlock Text="Your explanation" Style="{StaticResource FieldLabel}" Margin="0,18,0,3" />
                            <TextBox Text="{Binding Learning.EvaluationAnswer, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" MinHeight="110" TextWrapping="Wrap" />
                            <WrapPanel Margin="0,12,0,0">
                                <Button Content="Copy Prompt for AI" Command="{Binding Learning.CopyEvaluationPromptCommand}" Background="{StaticResource DS_AccentBrush}" Foreground="#111111" />
                                <Button Content="Local Check" Command="{Binding Learning.EvaluateUnderstandingCommand}" />
                            </WrapPanel>
                            <TextBlock Text="Paste AI JSON result" Style="{StaticResource FieldLabel}" Margin="0,16,0,3" />
                            <TextBox Text="{Binding Learning.EvaluationJson, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" MinHeight="120" TextWrapping="Wrap" />
                            <Border Background="{StaticResource DS_PanelSurfaceBrush}" CornerRadius="6,6,6,6" Padding="12" Margin="0,14,0,0">
                                <StackPanel>
                                    <TextBlock Text="{Binding Learning.EvaluationScore, StringFormat=Score: {0}/100}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Learning.EvaluationFeedback}" TextWrapping="Wrap" Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                            <WrapPanel Margin="0,14,0,0">
                                <Button Content="Parse AI Result" Command="{Binding Learning.ParseEvaluationResultCommand}" />
                                <Button Content="Start Trade Idea" Command="{Binding NextStepCommand}" IsEnabled="{Binding Learning.CanApplySelectedLesson}" Background="{StaticResource DS_AccentBrush}" Foreground="#111111" />
                            </WrapPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <Border Style="{StaticResource Panel}" Visibility="{Binding CurrentStep, Converter={StaticResource StringEqualsConverter}, ConverterParameter=PlanSetup}">
                    <StackPanel>
                        <TextBlock Text="What trade idea are you practicing?" Style="{StaticResource DS_Title22}" />
                        <TextBlock Text="Write the idea before calculating risk." Foreground="{StaticResource DS_SecondaryTextBrush}" Margin="0,4,0,14" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,10,0">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="Pair / Instrument" />
                                <TextBox Text="{Binding Planner.Plan.Pair, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Style="{StaticResource FieldLabel}" Text="Direction" />
                                <ComboBox SelectedValue="{Binding Planner.Plan.Direction}" SelectedValuePath="Content">
                                    <ComboBoxItem Content="Buy" />
                                    <ComboBoxItem Content="Sell" />
                                </ComboBox>
                                <TextBlock Style="{StaticResource FieldLabel}" Text="Setup Type" />
                                <TextBox Text="{Binding Planner.Plan.SetupType, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="Reason for trade" />
                                <TextBox Text="{Binding Planner.Plan.Reason, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" MinHeight="110" TextWrapping="Wrap" />
                                <TextBlock Style="{StaticResource FieldLabel}" Text="Invalidation" />
                                <TextBox Text="{Binding Planner.Plan.Invalidation, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" MinHeight="70" TextWrapping="Wrap" />
                            </StackPanel>
                        </Grid>
                        <Button Content="Continue to prices" Command="{Binding NextStepCommand}" HorizontalAlignment="Left" Margin="0,16,0,0" Background="{StaticResource DS_AccentBrush}" Foreground="#111111" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Panel}" Visibility="{Binding CurrentStep, Converter={StaticResource StringEqualsConverter}, ConverterParameter=EnterPrices}">
                    <StackPanel MaxWidth="560" HorizontalAlignment="Left">
                        <TextBlock Text="Enter prices and risk" Style="{StaticResource DS_Title22}" />
                        <TextBlock Text="Use the values you will manually enter in XM demo." Foreground="{StaticResource DS_SecondaryTextBrush}" Margin="0,4,0,14" />
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Entry" />
                        <TextBox Text="{Binding Planner.Plan.Entry, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Stop Loss" />
                        <TextBox Text="{Binding Planner.Plan.StopLoss, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Take Profit" />
                        <TextBox Text="{Binding Planner.Plan.TakeProfit, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Risk %" />
                        <TextBox Text="{Binding Planner.Plan.RiskPercent, UpdateSourceTrigger=PropertyChanged}" />
                        <WrapPanel Margin="0,16,0,0">
                            <Button Content="Calculate Risk" Command="{Binding Planner.CalculateRiskCommand}" />
                            <Button Content="Continue" Command="{Binding NextStepCommand}" Background="{StaticResource DS_AccentBrush}" Foreground="#111111" />
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Panel}" Visibility="{Binding CurrentStep, Converter={StaticResource StringEqualsConverter}, ConverterParameter=CheckRisk}">
                    <ScrollViewer>
                        <StackPanel>
                            <TextBlock Text="Risk check" Style="{StaticResource DS_Title22}" />
                            <TextBlock Text="{Binding Planner.Risk.BeginnerExplanation}" TextWrapping="Wrap" Foreground="{StaticResource DS_SecondaryTextBrush}" Margin="0,6,0,14" />
                            <WrapPanel>
                                <Border Style="{StaticResource Metric}"><StackPanel><TextBlock Text="Lot Size" /><TextBlock Text="{Binding Planner.Risk.LotSize, TargetNullValue='-'}" FontSize="22" /></StackPanel></Border>
                                <Border Style="{StaticResource Metric}"><StackPanel><TextBlock Text="Money Risk" /><TextBlock Text="{Binding Planner.Risk.MoneyRisk, StringFormat=C, TargetNullValue='-'}" FontSize="22" /></StackPanel></Border>
                                <Border Style="{StaticResource Metric}"><StackPanel><TextBlock Text="Reward" /><TextBlock Text="{Binding Planner.Risk.PotentialReward, StringFormat=C, TargetNullValue='-'}" FontSize="22" /></StackPanel></Border>
                                <Border Style="{StaticResource Metric}"><StackPanel><TextBlock Text="RR" /><TextBlock Text="{Binding Planner.Risk.RewardRiskRatio, TargetNullValue='-'}" FontSize="22" /></StackPanel></Border>
                            </WrapPanel>
                            <CheckBox Content="Checklist complete" IsChecked="{Binding Planner.ChecklistComplete}" Margin="0,16,0,6" />
                            <CheckBox Content="News checked" IsChecked="{Binding Planner.Plan.NewsChecked}" Margin="0,2,0,12" />
                            <Button Content="Check Rules" Command="{Binding Planner.CheckRulesCommand}" HorizontalAlignment="Left" />
                            <ItemsControl ItemsSource="{Binding Planner.RuleChecks}" Margin="0,12,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock TextWrapping="Wrap" Margin="0,3">
                                            <Run Text="{Binding Severity}" />
                                            <Run Text=" - " />
                                            <Run Text="{Binding Message}" />
                                        </TextBlock>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Button Content="Continue to screenshot" Command="{Binding NextStepCommand}" HorizontalAlignment="Left" Margin="0,16,0,0" Background="{StaticResource DS_AccentBrush}" Foreground="#111111" />
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <Border Style="{StaticResource Panel}" Visibility="{Binding CurrentStep, Converter={StaticResource StringEqualsConverter}, ConverterParameter=CaptureScreenshot}">
                    <StackPanel MaxWidth="760" HorizontalAlignment="Left">
                        <TextBlock Text="Capture before-trade screenshot" Style="{StaticResource DS_Title22}" />
                        <TextBlock Text="This saves visual evidence of what you saw before manually placing the XM demo trade." TextWrapping="Wrap" Foreground="{StaticResource DS_SecondaryTextBrush}" Margin="0,6,0,16" />
                        <TextBlock Text="{Binding Planner.Plan.Pair}" FontSize="18" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding Planner.Status}" TextWrapping="Wrap" Margin="0,8,0,16" />
                        <WrapPanel>
                            <Button Content="Open XM Broker" Command="{Binding GoToStepCommand}" CommandParameter="{x:Static shell:GuidedStep.ManualExecution}" />
                            <Button Content="Capture Before Screenshot" Click="CaptureBefore_Click" Background="{StaticResource DS_AccentBrush}" Foreground="#111111" />
                            <Button Content="Continue" Command="{Binding NextStepCommand}" />
                        </WrapPanel>
                        <TextBlock Text="Captured screenshots" Style="{StaticResource DS_SectionTitle16}" Margin="0,22,0,8" />
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding Planner.Screenshots}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource DS_PanelSurfaceBrush}" CornerRadius="6,6,6,6" Padding="8" Margin="0,0,10,0" Width="190">
                                            <StackPanel>
                                                <Image Source="{Binding FilePath}" Width="174" Height="98" Stretch="UniformToFill" />
                                                <TextBlock Text="{Binding CaptureType}" FontWeight="SemiBold" Margin="0,8,0,2" />
                                                <TextBlock Text="{Binding FilePath}" TextWrapping="Wrap" Foreground="{StaticResource DS_SecondaryTextBrush}" FontSize="10" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>

                <Grid Visibility="{Binding CurrentStep, Converter={StaticResource StringEqualsConverter}, ConverterParameter=ManualExecution}">
                    <DockPanel Margin="8">
                        <Border DockPanel.Dock="Top" Background="{StaticResource DS_SecondaryBgBrush}" CornerRadius="6,6,6,6" Padding="8" Margin="0,0,0,8">
                            <DockPanel>
                                <WrapPanel DockPanel.Dock="Right">
                                    <Button Content="Back" Click="BrowserBack_Click" />
                                    <Button Content="Forward" Click="BrowserForward_Click" />
                                    <Button Content="Refresh" Click="BrowserRefresh_Click" />
                                    <Button Content="Mark Placed" Command="{Binding Planner.MarkManuallyPlacedCommand}" Background="{StaticResource DS_AccentBrush}" Foreground="#111111" />
                                </WrapPanel>
                                <ItemsControl ItemsSource="{Binding Broker.Bookmarks}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Content="{Binding Name}"
                                                    Command="{Binding DataContext.Broker.OpenBookmarkCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </DockPanel>
                        </Border>
                        <wv2:WebView2 x:Name="BrokerWebView" Source="{Binding Broker.ActiveUrl, Converter={StaticResource UrlToUriConverter}}" />
                    </DockPanel>
                </Grid>

                <Border Style="{StaticResource Panel}" Visibility="{Binding CurrentStep, Converter={StaticResource StringEqualsConverter}, ConverterParameter=JournalReview}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="300" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="Journal drafts" Style="{StaticResource DS_SectionTitle16}" Margin="0,0,0,8" />
                            <DataGrid ItemsSource="{Binding Journal.Entries}" SelectedItem="{Binding Journal.SelectedEntry}" AutoGenerateColumns="False" CanUserAddRows="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Pair" Binding="{Binding Plan.Pair}" />
                                    <DataGridTextColumn Header="P/L" Binding="{Binding ProfitLoss}" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                        <ScrollViewer Grid.Column="1" Margin="18,0,0,0">
                            <StackPanel>
                                <TextBlock Text="Record result and lesson" Style="{StaticResource DS_Title22}" />
                                <TextBlock Style="{StaticResource FieldLabel}" Text="Profit / Loss" />
                                <TextBox Text="{Binding Journal.SelectedEntry.ProfitLoss, UpdateSourceTrigger=PropertyChanged}" />
                                <CheckBox Content="Followed plan" IsChecked="{Binding Journal.SelectedEntry.FollowedPlan}" Margin="0,10,0,0" />
                                <TextBlock Style="{StaticResource FieldLabel}" Text="Mistake Tags" />
                                <TextBox Text="{Binding Journal.MistakeTagsText, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Style="{StaticResource FieldLabel}" Text="Lesson Learned" />
                                <TextBox Text="{Binding Journal.SelectedEntry.LessonLearned, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" MinHeight="90" TextWrapping="Wrap" />
                                <TextBlock Style="{StaticResource FieldLabel}" Text="Review Notes" />
                                <TextBox Text="{Binding Journal.SelectedEntry.ReviewNotes, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" MinHeight="90" TextWrapping="Wrap" />
                                <TextBlock Text="Screenshots" Style="{StaticResource DS_SectionTitle16}" Margin="0,18,0,8" />
                                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                    <ItemsControl ItemsSource="{Binding Journal.SelectedEntry.Screenshots}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{StaticResource DS_PanelSurfaceBrush}" CornerRadius="6,6,6,6" Padding="8" Margin="0,0,10,0" Width="190">
                                                    <StackPanel>
                                                        <Image Source="{Binding FilePath}" Width="174" Height="98" Stretch="UniformToFill" />
                                                        <TextBlock Text="{Binding CaptureType}" FontWeight="SemiBold" Margin="0,8,0,2" />
                                                        <TextBlock Text="{Binding FilePath}" TextWrapping="Wrap" Foreground="{StaticResource DS_SecondaryTextBrush}" FontSize="10" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                                <WrapPanel Margin="0,12,0,0">
                                    <Button Content="Save Review" Command="{Binding Journal.SaveSelectedCommand}" />
                                    <Button Content="Mark Reviewed" Command="{Binding Journal.MarkReviewedCommand}" />
                                    <Button Content="Export AI Review" Command="{Binding ExportAiReviewCommand}" Background="{StaticResource DS_AccentBrush}" Foreground="#111111" />
                                </WrapPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Column="2" Style="{StaticResource Panel}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Need help?" Style="{StaticResource DS_SectionTitle16}" />
                        <TextBlock Text="Press this before asking any AI. It copies your lesson, plan, risk, rules, notes, and screenshot paths." TextWrapping="Wrap" Foreground="{StaticResource DS_SecondaryTextBrush}" Margin="0,8,0,10" />
                        <TextBlock Text="Question for AI" Foreground="{StaticResource DS_SecondaryTextBrush}" />
                        <TextBox Text="{Binding AiReviewQuestion, UpdateSourceTrigger=PropertyChanged}" MinHeight="34" MaxHeight="42" TextWrapping="NoWrap" />
                        <Button Content="Copy Situation for AI" Command="{Binding ExportAiReviewCommand}" Background="{StaticResource DS_AccentBrush}" Foreground="#111111" Margin="0,10,0,18" />
                        <TextBlock Text="{Binding CurrentStepTitle}" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding CurrentStepHelp}" TextWrapping="Wrap" Foreground="{StaticResource DS_SecondaryTextBrush}" Margin="0,6,0,16" />
                        <Button Content="Back" Command="{Binding PreviousStepCommand}" />
                        <Button Content="{Binding NextButtonText}" Command="{Binding NextStepCommand}" Background="{StaticResource DS_AccentBrush}" Foreground="#111111" />
                        <Button Content="Save Draft" Command="{Binding Planner.SaveJournalDraftCommand}" />
                        <TextBlock Text="{Binding Status}" TextWrapping="Wrap" Foreground="{StaticResource DS_SecondaryTextBrush}" Margin="0,12,0,0" />
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border x:Name="ProgressOverlay" Grid.RowSpan="2" Background="#00000060" Visibility="Collapsed" Panel.ZIndex="20" Width="320" Height="110" CornerRadius="6,6,6,6">
            <StackPanel VerticalAlignment="Center" Margin="16">
                <TextBlock x:Name="ProgressTitle" Text="Working..." FontWeight="SemiBold" />
                <ProgressBar x:Name="ProgressBar" Height="8" Margin="0,12,0,6" />
                <TextBlock x:Name="ProgressPercentage" Text="0%" HorizontalAlignment="Right" Foreground="{StaticResource DS_SecondaryTextBrush}" />
            </StackPanel>
        </Border>
        <StackPanel x:Name="ToastContainer" Grid.RowSpan="2" Panel.ZIndex="30" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="16" />
    </Grid>
</Window>
